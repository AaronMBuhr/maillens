# MailLens Environment Variables
# Copy to .env and fill in your values

# Path to your Thunderbird profile directory on the HOST machine
# e.g., /home/youruser/.thunderbird/xxxxxxxx.default-release
# On Windows via WSL: /mnt/c/Users/you/AppData/Roaming/Thunderbird/Profiles/xxxxxxxx.default-release
MAILLENS_MAIL_DIR=./_mail

# LLM API keys (at least one required unless using Ollama only)
MAILLENS_GEMINI_API_KEY=
MAILLENS_ANTHROPIC_API_KEY=
MAILLENS_OPENAI_API_KEY=

# Database password (override config.yaml value)
MAILLENS_DB_PASSWORD=maillens

# Port to expose the web UI on
MAILLENS_PORT=8000
